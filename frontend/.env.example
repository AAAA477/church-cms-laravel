# Public URL of the Laravel backend API. Do not include a trailing slash.
API_URL=https://api.example.com

# Public URL of the deployed frontend, used for robots.txt and sitemap.xml.
# Netlify provides URL/DEPLOY_PRIME_URL automatically, so set this only when
# you need to override the generated value.
SITE_URL=https://your-site.netlify.app

# Single-church install: mirrors PRIMARY_CHURCH_ID in the Laravel .env.
CHURCH_ID=1
