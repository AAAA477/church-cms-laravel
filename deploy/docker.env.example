# Copy to deploy/docker.env and fill in. Shared by db, backend, scheduler,
# and frontend containers (each ignores keys it doesn't use).
# deploy/docker.env is gitignored — never commit the filled-in copy.

# ---- Postgres (db container bootstrap; must match PGSQL_* below) ----
POSTGRES_DB=churchcms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE-ME-strong-password

# ---- Laravel ----
APP_NAME=ChurchCMS
APP_ENV=production
# Copy APP_KEY from your local .env (existing encrypted data depends on it),
# or generate a fresh one for a clean install:
#   docker compose run --rm backend php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
# The public origin. Local topology test: http://localhost:8090
# Production: https://your-domain.com
APP_URL=http://localhost:8090

CHURCH_INSTALLED=true
PRIMARY_CHURCH_ID=1

DB_CONNECTION=pgsql
PGSQL_HOST=db
PGSQL_PORT=5432
PGSQL_DATABASE=churchcms
PGSQL_USERNAME=postgres
PGSQL_PASSWORD=CHANGE-ME-strong-password

# Behind the nginx container, so trust the proxy chain for real client IPs
# (prayer-lift dedup hashes, activity logs).
TRUSTED_PROXIES=*
# Same-origin in this topology; keep in sync with APP_URL.
FRONTEND_URL=http://localhost:8090

LOG_CHANNEL=stderr
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync
FILESYSTEM_DRIVER=local
SESSION_LIFETIME=120
CACHE_TIME=84000
APP_TIMEZONE=UTC
TIMEZONE=UTC

# ---- Mail (log driver = writes to logs instead of sending; set up a real
# ---- SMTP provider for production password resets etc.) ----
MAIL_DRIVER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_STATUS=on
REMINDER=mail
SMS_STATUS=off

# ---- Payment gateways (fill in only what you use) ----
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=
GCASH_PUBLIC_KEY=
GCASH_SECRET_KEY=
GCASH_CURRENCY=PHP
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=

# ---- Next.js frontend (runtime; build-time values are compose build args) ----
# Internal service-to-service URL — the frontend container reaches Laravel
# directly, not through nginx.
API_URL=http://backend
CHURCH_ID=1
# Public origin again (sitemap/robots/canonical URLs). Keep in sync with APP_URL.
SITE_URL=http://localhost:8090
